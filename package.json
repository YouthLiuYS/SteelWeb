{
  "name": "steel-mesh-site",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:github": "SITE_BASE_PATH=/SteelWeb next build",
    "build:gitee": "SITE_BASE_PATH=/SteelWeb next build",
    "start": "next start",
    "content:apply": "node scripts/apply-content.js",
    "prepare:static": "npm run content:apply && npm run build",
    "prepare:static:gitee": "npm run content:apply && npm run build:gitee",
    "deploy:gitee": "bash scripts/deploy-gitee.sh"
  },
  "dependencies": {
    "next": "14.2.3",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@types/node": "20.11.30",
    "@types/react": "18.2.79",
    "typescript": "5.3.3"
  }
}
